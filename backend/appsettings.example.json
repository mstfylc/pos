{
  "$comment": "Bu bir ŞABLONDUR. Gerçek değerler environment variable / user-secrets / secret manager'dan gelir. appsettings.json commit EDİLMEZ (.gitignore'da).",
  "AppSettings": {
    "JwtSecret": "${JWT_SECRET}",
    "JwtAccessTokenMinutes": 15,
    "JwtRefreshTokenDays": 30,
    "MailHost": "${MAIL_HOST}",
    "MailUsername": "${MAIL_USERNAME}",
    "MailPassword": "${MAIL_PASSWORD}",
    "SmsApiUrl": "${SMS_API_URL}",
    "SmsApiUsername": "${SMS_API_USERNAME}",
    "SmsApiPassword": "${SMS_API_PASSWORD}"
  },
  "ConnectionStrings": {
    "Default": "${DB_CONNECTION_STRING}"
  },
  "Cors": {
    "AllowedOrigins": ["https://admin.example.com", "https://pos.example.com"]
  },
  "AllowedHosts": "*"
}
